# Copy this file to .env and replace the placeholder with a FRESH userauth value.
MADGETECH_USERAUTH=userauth

MADGETECH_LOGGER_ID=id number
MADGETECH_LOGGER_SERIAL=logger serial number

# 1 means the backend asks MadgeTech Cloud every second.
# The logger is configured to create a new sensor reading every 60 seconds,
# so 60 is the safer recommended value for normal use.
CLOUD_POLL_SECONDS=60

REQUEST_TIMEOUT_SECONDS=15
